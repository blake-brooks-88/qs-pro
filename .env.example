NODE_ENV=development

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_dev_only
POSTGRES_DB=qs_pro

# Postgres app roles (created on first `docker compose up` via docker/postgres/init/)
# IMPORTANT: qs_migrate has BYPASSRLS and is intended ONLY for schema migrations and test/CI cleanup.
# Application runtime must use qs_runtime (non-BYPASSRLS) for DATABASE_URL.
# qs_backoffice has BYPASSRLS for cross-tenant admin queries (backoffice portal only).
# Security boundary: table-level GRANT allowlist (no default table privileges).
QS_DB_MIGRATE_USER=qs_migrate
QS_DB_MIGRATE_PASSWORD=change_me_dev_only
QS_DB_RUNTIME_USER=qs_runtime
QS_DB_RUNTIME_PASSWORD=change_me_dev_only

# Example URLs
DATABASE_URL=postgres://qs_runtime:change_me_dev_only@127.0.0.1:5432/qs_pro
DATABASE_URL_MIGRATIONS=postgres://qs_migrate:change_me_dev_only@127.0.0.1:5432/qs_pro

# Redis URL
REDIS_URL=redis://localhost:6379

# =============================================================================
# Sentry (optional)
# =============================================================================
# You can use a single project DSN for all services with SENTRY_DSN, or split
# per-service using SENTRY_DSN_API and SENTRY_DSN_WORKER.
# Frontend (Vite) uses VITE_SENTRY_DSN (configure in apps/web/.env.local).
# SENTRY_ENVIRONMENT=local
# SENTRY_DSN=
# SENTRY_DSN_API=
# SENTRY_DSN_WORKER=

# =============================================================================
# Session & Encryption (REQUIRED)
# =============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-secret-at-least-32-characters-long
SESSION_SALT=your-salt-at-least-16-chars
APP_WEB_ORIGIN=http://localhost:5173

# 256-bit AES key for encrypting tokens at rest (64 hex chars = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=<generate-64-hex-chars-using-command-above>

# =============================================================================
# MCE OAuth (REQUIRED for authentication)
# =============================================================================
# Obtain from Marketing Cloud Setup > Installed Packages
MCE_CLIENT_ID=your-mce-client-id
MCE_CLIENT_SECRET=your-mce-client-secret
MCE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# JWT verification secret (from your MCE Installed Package)
MCE_JWT_SIGNING_SECRET=your-jwt-signing-secret-at-least-32-chars

# Optional: JWT issuer/audience for strict validation
# MCE_JWT_ISSUER=
# MCE_JWT_AUDIENCE=

# =============================================================================
# Stripe Billing
# =============================================================================
# Required in production when the API is deployed with billing enabled.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_API_VERSION=2024-06-20
# STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# Cookie Settings
# =============================================================================
# Defaults (recommended for MCE): COOKIE_SECURE=true and COOKIE_SAMESITE=none.
# - Local dev over http: set COOKIE_SECURE=false and COOKIE_SAMESITE=lax.
# - Embedded in MCE iframe over https: set COOKIE_SECURE=true and COOKIE_SAMESITE=none.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# Optional: Set domain for cross-subdomain cookies (cannot be used with COOKIE_PARTITIONED=true)
# COOKIE_DOMAIN=
# Optional: Enable partitioned cookies (defaults to true when COOKIE_SAMESITE=none)
# COOKIE_PARTITIONED=true

# =============================================================================
# Metrics (optional)
# =============================================================================
# When set, the /metrics endpoint requires Authorization: Bearer <key>.
# Leave unset for local dev. In production, set this or ensure /metrics is only
# reachable via infra-level protection (ingress auth, network policy, etc.).
# METRICS_API_KEY=

# Worker Admin API Key (required for Bull Board UI access at /admin/queues)
# Set a strong random key in production. Access Bull Board with header: x-admin-key: <your-key>
ADMIN_API_KEY=change_me_dev_only

# =============================================================================
# Backoffice
# =============================================================================
BACKOFFICE_API_PORT=3002
BACKOFFICE_WEB_ORIGIN=http://localhost:5174
QS_DB_BACKOFFICE_USER=qs_backoffice
QS_DB_BACKOFFICE_PASSWORD=change_me_dev_only
DATABASE_URL_BACKOFFICE=postgres://qs_backoffice:change_me_dev_only@127.0.0.1:5432/qs_pro
BETTER_AUTH_SECRET=           # Required — used by Better Auth for token signing. Generate with: openssl rand -base64 32
# STRIPE_SECRET_KEY is shared with main API (already defined above)

# Backoffice Admin Seed (one-time use)
SEED_ADMIN_EMAIL=             # Email for the initial admin user
SEED_ADMIN_PASSWORD=          # Password for the initial admin user (min 8 chars)
SEED_ADMIN_NAME=              # Display name for the initial admin user
